# === LLM Configuration (single source of truth) ===
# Switch providers by changing these 4 values. They override config.yaml's llm.providers entries.
#   BLSC:      LLM_BASE_URL=https://llmapi.blsc.cn/v1/   LLM_MODEL_CHEAP=DeepSeek-V4-Flash    LLM_MODEL_STRONG=DeepSeek-V4-Pro
#   Official:  LLM_BASE_URL=https://api.deepseek.com      LLM_MODEL_CHEAP=deepseek-v4-flash    LLM_MODEL_STRONG=deepseek-v4-pro
DEEPSEEK_API_KEY=
LLM_BASE_URL=
LLM_MODEL_CHEAP=
LLM_MODEL_BALANCED=
LLM_MODEL_STRONG=
OPENAI_API_KEY=

ZOTERO_API_KEY=
ZOTERO_USER_ID=
ZOTERO_LIBRARY_TYPE=user
COLLECTION_ID=
# Optional: use distinct variables referenced by project.topics.*.collection_id_env.
# TEST_COLLECTION_ID=
# PROD_COLLECTION_ID=

NOTION_TOKEN=
NOTION_DATABASE_ID=
# Optional with Notion API 2025-09-03; otherwise discovered from the database.
NOTION_DATA_SOURCE_ID=

OBSIDIAN_VAULT_PATH=

PDF2ZH_EXECUTABLE=pdf2zh
